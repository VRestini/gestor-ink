<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppGestorInk.MVVM.Views.Estoque"
             xmlns:local="clr-namespace:AppGestorInk.MVVM.Models"
             xmlns:model="clr-namespace:AppGestorInk.MVVM.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodel="clr-namespace:AppGestorInk.MVVM.ViewModels"
             x:DataType="viewmodel:EstoqueViewModel"
             >
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior Command="{Binding GetProdutoCommand}" EventName="Appearing" />
    </ContentPage.Behaviors>
    <Shell.TitleView>
        <FlexLayout JustifyContent="End" AlignItems="Center" AlignContent="End" >
            <Button 
                CornerRadius="100" Text="+" TextColor="White" 
                BackgroundColor="#101010" FontSize="25"
                Command="{Binding AddProdutoCommand}" />
        </FlexLayout>

    </Shell.TitleView>
    <Grid BackgroundColor="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        

        <ScrollView Grid.Row="0">
            
            <FlexLayout  Direction="Column"
                AlignItems="Center"        
                JustifyContent="Start"
                >

                <Frame BackgroundColor="#101010" CornerRadius="100" WidthRequest="320" HeightRequest="50" Margin="0, 15, 0, 0">
                    <SearchBar Placeholder="Search items..." HeightRequest="30"/>
                </Frame>
                <CollectionView x:Name="ProdutoCV" ItemsSource="{Binding ProdutoList}"
                                >
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:Produto">
                            <Border BackgroundColor="#101010" HeightRequest="134" WidthRequest="320" Padding="13" Margin="0, 15, 0, 0" >
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" BackgroundColor="#101010"/>
                                </Border.StrokeShape>
                                <FlexLayout >
                                    <Image Source="dotnet_bot.png"
HeightRequest="114" WidthRequest="88" />
                                    <HorizontalStackLayout>
                                        
                                        <VerticalStackLayout WidthRequest="176" >
                                            <Label Text="{Binding Name}" FontSize="Subtitle" TextColor="White" FontAttributes="Bold" MaxLines="1" Margin="3,0,0,0"/>
                                            <Label Text="{Binding Descricao}" FontSize="Caption" TextColor="White" FontFamily=""/>
                                        </VerticalStackLayout>
                                        <FlexLayout WidthRequest="30"  Direction="Column" AlignItems="Center">
                                            <ImageButton
                                                 Source="editar.png"
                                                 HeightRequest="20"   
                                                 WidthRequest="20"
                                                 Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:EstoqueViewModel}}, Path=RefreshProdutoCommand}"
                                                 CommandParameter="{Binding .}"
                                                 Margin="0, 2, 0, 0"/>
                                            <ImageButton
                                                Margin="0, 5,0,0"
                                                Source="relatorio.png"
                                                HeightRequest="20"   
                                                WidthRequest="20"
                                                />
                                            
                                        </FlexLayout>
                                    </HorizontalStackLayout>
                                </FlexLayout>

                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </FlexLayout>
        </ScrollView>
    </Grid>
</ContentPage>