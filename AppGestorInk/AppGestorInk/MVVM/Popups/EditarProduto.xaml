<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             x:Class="AppGestorInk.MVVM.Popups.EditarProduto"
             xmlns:viewmodel="clr-namespace:AppGestorInk.MVVM.ViewModels"
             Title="EditarProduto"
             x:DataType="viewmodel:EditarProdutoViewModel">
   
    <VerticalStackLayout>
        <Border HeightRequest="60" BackgroundColor="WhiteSmoke">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15, 15, 0, 0" BackgroundColor="WhiteSmoke"/>
            </Border.StrokeShape>
            <Entry Text="{Binding Produto.Name}" TextColor="#101010" Placeholder="Nome:"></Entry>
        </Border>
        <StackLayout HeightRequest="10"></StackLayout>
        <Border HeightRequest="60">
            <Entry Text="{Binding Produto.Descricao}" TextColor="#101010" Placeholder="Descrição:"></Entry>
        </Border>
        <Button Command="{Binding RefreshProdutoCommand}" Text="Clica"/>
    </VerticalStackLayout>
</ContentPage>